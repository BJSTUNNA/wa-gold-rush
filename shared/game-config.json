  "netWorthCalculation": {
    "formula": "Cash + MineValue + MachineryValue",
    "components": {
      "cash": "Current available funds",
      "mineValue": "Sum of all owned mines' base values",
      "machineryValue": "Sum of all machinery item values"
    },
    "description": "Total net worth determines rank on leaderboard"
  },

  "teacherDashboard": {
    "features": [
      "student_import",
      "level_assignment",
      "progress_monitoring",
      "pause_game",
      "view_leaderboards",
